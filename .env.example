# BrandOS - Environment Variables
# Copy to .env.production and fill in values

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=40200

# ─── Database (PostgreSQL @ 192.168.0.41) ────────────────────────────────────
DATABASE_URL=postgresql://brandos_user:PASSWORD@192.168.0.41:5432/brandos_db

# ─── Session JWT ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here

# ─── JLC SSO (OAuth2) ────────────────────────────────────────────────────────
# Internal URL for server-to-server token exchange
JLC_SSO_URL=http://localhost:10100
JLC_SSO_CLIENT_ID=client_xxxxx
JLC_SSO_CLIENT_SECRET=secret_xxxxx

# ─── Frontend env (Vite inlines at build time) ───────────────────────────────
# Public URL for browser redirects to SSO login page
VITE_JLC_SSO_URL=https://sso.jlcgroup.co
VITE_JLC_SSO_CLIENT_ID=client_xxxxx

# ─── LLM / AI (Manus built-in) ───────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
